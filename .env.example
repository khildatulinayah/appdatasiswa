# Google OAuth2 Configuration
# Get these credentials from Google Cloud Console
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google+ API and Google OAuth2 API
# 4. Create OAuth2 Client ID for Web Application
# 5. Add your redirect URI to authorized redirect URIs

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/app-siswa1/modules/auth/google_callback.php

# For production, change the redirect URI to your production URL
# GOOGLE_REDIRECT_URI=https://yourdomain.com/modules/auth/google_callback.php
